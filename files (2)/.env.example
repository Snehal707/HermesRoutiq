# --- Map / frontend ---
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only secrets (NEVER exposed to Hermes) ---
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
REDIS_URL=

# --- Stripe (sandbox) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- NVIDIA cuOpt ---
# Managed endpoint OR self-hosted NIM. Provider interface handles either.
CUOPT_API_URL=
CUOPT_API_KEY=

# --- Hermes reasoning model (Nemotron 3 Ultra) ---
# Configured through `hermes model` provider selection, not a separate SDK.
# Scoped to Hermes's own runtime; never exposed to MCP tools or Node core.
# PRIMARY: Nous Portal, billed against existing Nous API credits.
NOUS_API_KEY=
# FALLBACK: OpenRouter, same model family. One-line `hermes model` switch if Nous Portal hiccups.
OPENROUTER_API_KEY=
NEMOTRON_MODEL_ID=nvidia/nemotron-3-ultra

# --- Agent ---
HERMES_API_URL=
MCP_SERVER_URL=

# --- Simulation ---
SIMULATION_SEED=42
SIMULATION_MODE=demo
MAX_AUTOMATIC_INCIDENT_SPEND=20
