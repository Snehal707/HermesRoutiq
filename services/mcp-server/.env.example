# Hermes Routiq MCP server
# Copy to services/mcp-server/.env and fill in values.
# The server also inherits from repo-root .env and apps/web/.env.local if present.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Redis (required) ---
REDIS_URL=

# --- Stripe sandbox (required for payouts / checkout tools) ---
STRIPE_SECRET_KEY=
STRIPE_CONNECT_SECRET_KEY=

# --- Routing service (optional) ---
ROUTING_SERVICE_URL=http://127.0.0.1:8001

# --- Spend policy (optional) ---
# Automatic incident spend cap in USD before human approval is required.
MAX_AUTOMATIC_INCIDENT_SPEND=20

# --- MCP HTTP transport (optional) ---
# Hermes inside NemoClaw reaches this server from the Windows/WSL host.
MCP_HTTP_ENABLED=true
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8644
MCP_HTTP_PATH=/mcp
MCP_SSE_PATH=/sse
MCP_SSE_MESSAGES_PATH=/messages
# Comma-separated Host header allowlist. Include localhost plus the host IP
# your sandbox uses (often the WSL/Windows gateway, e.g. 172.20.96.1).
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,host.openshell.internal

# --- Reasoning route (optional) ---
# Where the MCP server sends a reasoning request:
#   hermes_local (default): delegate to the Hermes agent via the bridge below;
#     the agent reasons with Nemotron 3 Ultra (over OpenRouter) inside the sandbox.
#   nous / openrouter: skip the agent and call a raw Nemotron model directly
#     (requires NOUS_API_KEY or OPENROUTER_API_KEY respectively).
LLM_PROVIDER=hermes_local
HERMES_BRIDGE_URL=http://127.0.0.1:8650/v1
# Set this to YOUR actual WSL distro (e.g. Ubuntu, Ubuntu-24.04).
HERMES_WSL_DISTRO=Ubuntu-24.04
HERMES_SANDBOX_NAME=hermes-runway
NEMOTRON_MODEL_ID=nvidia/nemotron-3-ultra-550b-a55b
# OPENROUTER_API_KEY=

# --- Dashboard links in tool responses (optional) ---
# Must match where the Next.js dashboard actually runs (default 3001).
HERMES_DASHBOARD_BASE_URL=http://127.0.0.1:3001
