# --- Map / frontend ---
NEXT_PUBLIC_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
NEXT_PUBLIC_SIMULATION_SEED=42
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only secrets (NEVER exposed to Hermes) ---
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
REDIS_URL=

# --- Stripe (sandbox) ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CONNECT_SECRET_KEY=
STRIPE_CONNECT_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- NVIDIA cuOpt ---
# Managed endpoint OR self-hosted NIM. Provider interface handles either.
CUOPT_API_URL=
CUOPT_API_KEY=

# --- Hermes reasoning model (Nemotron 3 Ultra) ---
# Provisioned at NemoClaw / NemoHermes onboarding, NOT via app env here.
# The sandbox is wired to Nemotron 3 Ultra through OpenRouter's OpenAI-compatible
# endpoint (NemoClaw `compatible-endpoint` provider, NEMOCLAW_ENDPOINT_URL=
# https://openrouter.ai/api/v1). Scoped to Hermes's own runtime inside the
# sandbox; never exposed to MCP tools or the Node core.
OPENROUTER_API_KEY=
NEMOTRON_MODEL_ID=nvidia/nemotron-3-ultra-550b-a55b

# --- Agent ---
HERMES_API_URL=
MCP_SERVER_URL=

# --- Simulation ---
SIMULATION_SEED=42
SIMULATION_MODE=demo
MAX_AUTOMATIC_INCIDENT_SPEND=20
