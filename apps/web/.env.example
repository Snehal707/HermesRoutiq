# Hermes Routiq web app (Next.js)
# Copy to apps/web/.env.local and fill in values.
# Next.js only auto-loads env files from this directory, so the frontend's
# NEXT_PUBLIC_* vars and server secrets must live here (not just repo-root .env).

# --- Supabase (required) ---
# Public keys are exposed to the browser; the service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Redis (required) ---
REDIS_URL=

# --- Stripe sandbox (required for checkout / payouts / refunds) ---
STRIPE_SECRET_KEY=
STRIPE_CONNECT_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Backend services (optional; sane localhost defaults) ---
# MCP server (Hermes tool layer)
MCP_CORE_URL=http://127.0.0.1:8644
# FastAPI routing service (cuOpt + OSRM)
ROUTING_SERVICE_URL=http://127.0.0.1:8001
# Ambient simulator
SIMULATOR_BASE_URL=http://127.0.0.1:8010
NEXT_PUBLIC_SIMULATION_BACKEND=http://127.0.0.1:8010
NEXT_PUBLIC_SIMULATION_BACKEND_ENABLED=true

# --- Map / simulation (optional) ---
NEXT_PUBLIC_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/positron-gl-style/style.json
NEXT_PUBLIC_SIMULATION_SEED=42
